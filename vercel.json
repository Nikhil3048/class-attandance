{
  "version": 2,
  "builds": [
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/server/index.js" },
    { "src": "/(css|js|assets)/(.*)", "dest": "/public/$1/$2" },
    { "src": "/(.*)", "dest": "/public/index.html" }
  ]
}
